# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# DATABASE_URL  → koneksi normal / PgBouncer pooling
# DIRECT_URL    → koneksi direct, wajib untuk migrate
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_random_string_panjang_minimal_32_karakter
JWT_REFRESH_SECRET=ganti_dengan_random_string_berbeda_minimal_32_karakter
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  BOOKING
  PAYMENT
  REVIEW
  SYSTEM
  VERIFICATION
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  avatar    String?
  role      Role     @default(CUSTOMER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor        Vendor?
  bookings      Booking[]
  reviews       Review[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Vendor {
  id             String       @id @default(cuid())
  userId         String       @unique
  businessName   String
  description    String?
  address        String?
  city           String?
  province       String?
  status         VendorStatus @default(PENDING)
  rejectedReason String?
  rating         Float        @default(0)
  totalReviews   Int          @default(0)
  totalBookings  Int          @default(0)
  bankName       String?
  bankAccount    String?
  bankHolder     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  layanan   Layanan[]
  portfolio Portfolio[]
  jadwal    Jadwal[]
  bookings  Booking[]
  reviews   Review[]

  @@map("vendors")
}

model Kategori {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  layanan Layanan[]

  @@map("kategori")
}

model Layanan {
  id          String   @id @default(cuid())
  vendorId    String
  kategoriId  String
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  duration    Int?
  images      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor   Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  kategori Kategori  @relation(fields: [kategoriId], references: [id])
  bookings Booking[]

  @@map("layanan")
}

model Portfolio {
  id          String    @id @default(cuid())
  vendorId    String
  title       String
  description String?
  imageUrl    String
  eventDate   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("portfolio")
}

model Jadwal {
  id          String   @id @default(cuid())
  vendorId    String
  date        DateTime @db.Date
  isAvailable Boolean  @default(true)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor  Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  booking Booking?

  @@unique([vendorId, date])
  @@map("jadwal")
}

model Booking {
  id           String        @id @default(cuid())
  customerId   String
  vendorId     String
  layananId    String
  jadwalId     String?       @unique
  eventDate    DateTime
  eventAddress String?
  notes        String?
  totalPrice   Decimal       @db.Decimal(12, 2)
  status       BookingStatus @default(PENDING)
  cancelReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customer User     @relation(fields: [customerId], references: [id])
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  layanan  Layanan  @relation(fields: [layananId], references: [id])
  jadwal   Jadwal?  @relation(fields: [jadwalId], references: [id])
  payment  Payment?
  review   Review?

  @@index([customerId])
  @@index([vendorId])
  @@map("bookings")
}

model Payment {
  id         String        @id @default(cuid())
  bookingId  String        @unique
  amount     Decimal       @db.Decimal(12, 2)
  status     PaymentStatus @default(PENDING)
  method     String?
  proofUrl   String?
  paidAt     DateTime?
  verifiedAt DateTime?
  verifiedBy String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  customerId String
  vendorId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customerId], references: [id])
  vendor   Vendor  @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("reviews")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}